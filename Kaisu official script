-- Функция вычисления хэша на стороне клиента
local function getExpectedHash()
    local dateTable = os.date("!*t")
    local str = string.format("%s_%d_%d_%d", SECRET_SALT, dateTable.day, dateTable.month, dateTable.year)
    local hash = 0
    for i = 1, #str do
        hash = hash + string.byte(str, i)
        hash = bit32.band(hash + bit32.lshift(hash, 10), 0xFFFFFFFF)
        hash = bit32.bxor(hash, bit32.rshift(hash, 6))
    end
    hash = hash + bit32.lshift(hash, 3)
    hash = bit32.bxor(hash, bit32.rshift(hash, 11))
    hash = bit32.band(hash + bit32.lshift(hash, 15), 0xFFFFFFFF)
    return "Kaisu_" .. string.format("%08x", hash)
end

